# Copie para .env e ajuste os valores.
# Senha do SA do SQL Server (requisitos Microsoft: maiúscula, minúscula, número e símbolo)
MSSQL_SA_PASSWORD=Satc#2026

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# JDBC — host/porta vistos pela máquina onde o Spark/notebook roda (localhost se os containers expõem as portas)
MSSQL_JDBC_HOST=localhost
MSSQL_JDBC_PORT=1433
MSSQL_JDBC_DATABASE=BibliotecaDb
MSSQL_JDBC_USER=sa
# Opcional: se vazio, o notebook usa MSSQL_SA_PASSWORD
MSSQL_JDBC_PASSWORD=
MSSQL_JDBC_ENCRYPT=false
MSSQL_JDBC_TRUST_SERVER_CERTIFICATE=true

# URL JDBC completa (alternativa: preencha esta variável e deixe o notebook usar só ela)
# Exemplo:
# MSSQL_JDBC_URL=jdbc:sqlserver://localhost:1433;databaseName=master;encrypt=false;trustServerCertificate=true
MSSQL_JDBC_URL=jdbc:sqlserver://localhost:1433;databaseName=BibliotecaDb;encrypt=false;trustServerCertificate=true

# Endpoint S3 para o Spark (MinIO na porta API). Use 127.0.0.1 se rodar o notebook no host com Docker.
MINIO_S3_ENDPOINT=http://127.0.0.1:9000
