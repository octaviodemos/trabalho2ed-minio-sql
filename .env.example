# Copie para a raiz do projeto: cp .env.example .env
# Senha do SA (requisitos Microsoft: maiúscula, minúscula, número e símbolo).
# Use aspas se a senha contiver # — caso contrário o carácter # inicia comentário no ficheiro.
MSSQL_SA_PASSWORD="altere-esta-senha-forte"

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

MSSQL_JDBC_HOST=localhost
MSSQL_JDBC_PORT=1433
MSSQL_JDBC_DATABASE=BibliotecaDb
MSSQL_JDBC_USER=sa
MSSQL_JDBC_PASSWORD=

MSSQL_JDBC_ENCRYPT=false
MSSQL_JDBC_TRUST_SERVER_CERTIFICATE=true

# Opcional: JDBC completo (sobrescreve host/porta/database acima).
# MSSQL_JDBC_URL=jdbc:sqlserver://localhost:1433;databaseName=BibliotecaDb;encrypt=false;trustServerCertificate=true

MINIO_S3_ENDPOINT=http://127.0.0.1:9000

# Opcional: força o driver ODBC no notebook 00 (pyodbc). Se vazio, escolhe-se automaticamente.
# MSSQL_ODBC_DRIVER={ODBC Driver 18 for SQL Server}
